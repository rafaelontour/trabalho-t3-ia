# Banco utilizado pelo fluxo com RAG
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/trabalho-t3

# Modelo de embedding já utilizado pelo projeto
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIMENSIONS=384

# Configure apenas o provider que será usado na execução
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
